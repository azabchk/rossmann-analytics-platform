# Public frontend configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Backend runtime configuration
APP_NAME=Sales Forecasting Platform API
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
ENABLE_LOCAL_DEMO_AUTH=false

# Supabase foundation
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=replace-with-local-jwt-secret
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Database connectivity
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
DATABASE_ECHO=false

# Data and ML runtime
ROSSMANN_TRAIN_PATH=./data/train.csv
ROSSMANN_STORE_PATH=./data/store.csv
FORECAST_HORIZON_DAYS=42
MODEL_ARTIFACT_BUCKET=model-artifacts
ML_ARTIFACT_LOCAL_PATH=./ml/models
